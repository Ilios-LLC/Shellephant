{
  "hasCompletedOnboarding": true,
  "theme": "dark",
  "teammateMode": "tmux",
  "customApiKeyResponses": {
    "approved": [],
    "rejected": []
  },
  "mcpServers": {
    "playwright": {
      "command": "/usr/local/share/npm-global/bin/playwright-mcp"
    },
    "tailwind-plus": {
      "command": "npx",
      "args": ["mcp-for-tailwind"]
    }
  },
  "projects": {
    "/workspace": {
      "hasTrustDialogAccepted": true,
      "hasCompletedProjectOnboarding": true,
      "projectOnboardingSeenCount": 1,
      "enabledMcpjsonServers": ["playwright", "tailwind-plus"],
      "enableAllProjectMcpServers": true
    }
  }
}
